flowchart TD
    Request["GET /api/v1/catalogs/order-form"]
    CacheCheck{"¿Existe en IMemoryCache?\nkey: order-form-catalogs:v1"}
    CacheHit["Retornar desde caché\nsource: cache\ndurationMs &lt; 50ms"]
    SlowSource["Consultar fuente lenta\nSimulación: delay ~2000ms\n(SlowCatalogSource)"]
    StoreCache["Guardar en IMemoryCache\nExpiry: 60 minutos"]
    Response["Response con metadata\n{ source, durationMs, cacheKey }"]

    Invalidate["POST /api/v1/catalogs/cache/invalidate"]
    InvalidateAction["Eliminar entrada del caché"]

    Request --> CacheCheck
    CacheCheck -->|"Sí (cache hit)"| CacheHit
    CacheCheck -->|"No (cache miss)"| SlowSource
    SlowSource --> StoreCache
    StoreCache --> Response
    CacheHit --> Response

    Invalidate --> InvalidateAction
    InvalidateAction -->|"Próxima petición vuelve al camino lento"| CacheCheck

    style CacheHit fill:#02FB90,color:#050505
    style SlowSource fill:#e5e9ee,color:#16171a
    style Invalidate fill:#9E2182,color:#ffffff
